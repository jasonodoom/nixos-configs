# Cached dev shell via nix-direnv. First entry builds the shell; every
# subsequent `cd` into the repo is instant (env is cached under .direnv/
# and only re-evaluated when flake.nix or flake.lock change).
#
# One-time per clone: `direnv allow`.

if ! has nix_direnv_version || ! nix_direnv_version 3.0.0; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="
fi

use flake

# Note: to silence direnv's "export +FOO +BAR" line, set DIRENV_LOG_FORMAT
# in your shell init (e.g. programs.bash.sessionVariables) — setting it
# here runs too late; direnv has already logged by the time .envrc evaluates.
