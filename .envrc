# direnv loads a small nix shell with pre-commit and installs the git
# hooks on first entry. Subsequent `cd` into the repo is instant (the
# hook install is skipped once .git/hooks/pre-commit exists).
#
# One-time setup per clone: `direnv allow` in this directory.

use nix -p pre-commit

if [ -d .git ] && [ -f .pre-commit-config.yaml ] && [ ! -f .git/hooks/pre-commit ]; then
  echo "installing pre-commit git hooks..."
  pre-commit install --install-hooks >/dev/null 2>&1 || true
fi
